# ============================================================================
# ProfJohns — environment
#
# SETUP:  cp .env.example .env.local   then fill in the REQUIRED block below.
# .env.local is gitignored — never commit real keys.
#
# On Vercel, add the same variables in Project → Settings → Environment
# Variables (at minimum the two NEXT_PUBLIC_SUPABASE_* keys, or auth + cloud
# sync silently stay off in production).
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED — AI features
# Get a key at https://openrouter.ai/keys
# Without it, every AI action (Sources scout, Synthesize, Draft, Assistant,
# Johns audit, Lily voice) shows a "not configured" message instead of running.
# ----------------------------------------------------------------------------
OPENROUTER_API_KEY=

# ----------------------------------------------------------------------------
# REQUIRED for accounts + cloud sync (Auth + Database + Storage)
# Create a free project at https://supabase.com, then copy these from
# Project → Settings → API. Leave BOTH blank to run in local-only mode
# (localStorage, no auth, no cross-device sync).
#
# After setting these: run supabase/schema.sql in the Supabase SQL editor,
# then (optional) enable Google OAuth in Auth → Providers → Google.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================================
# OPTIONAL — everything below has a sensible default; uncomment to override.
# ============================================================================

# Override which OpenRouter models each tier uses. Defaults shown.
#   FAST     — cheap, high-frequency calls (triage, chat, categorize)
#   (base)   — the everyday balanced model
#   FRONTIER — deepest reasoning (audit, synthesis)
# OPENROUTER_MODEL_FAST=anthropic/claude-haiku-4.5
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_MODEL_FRONTIER=anthropic/claude-opus-4

# Public base URL of your deployment — sent to OpenRouter as the referrer
# (their rankings) and used for absolute links. Default: localhost:3000.
# APP_URL=https://profjohns.vercel.app

# Contact email for OpenAlex's "polite pool" (faster, more reliable source
# search). Any email you own. Default: research@lattice.app.
# OPENALEX_MAILTO=you@example.com

# Lifts the aggressive rate limit on the keyless Semantic Scholar endpoint.
# Request one at https://www.semanticscholar.org/product/api . Optional.
# SEMANTIC_SCHOLAR_API_KEY=

# ----------------------------------------------------------------------------
# Background jobs — "work while you sleep" (Phase 4). SERVER-ONLY secrets.
# Only needed for the scheduled sweep (Vercel Cron → /api/jobs/run); the
# in-app "Run now" works without them. Set these in Vercel, not just locally.
# ----------------------------------------------------------------------------

# Supabase service-role key (Project → Settings → API → service_role). Lets the
# cron read every user's standing tasks + write findings, bypassing RLS.
# NEVER expose this to the client — no NEXT_PUBLIC_ prefix, never commit it.
# SUPABASE_SERVICE_ROLE_KEY=

# A random string. Vercel Cron sends it as `Authorization: Bearer <secret>`;
# the job route rejects anything else. Generate with: openssl rand -hex 32
# CRON_SECRET=

# ----------------------------------------------------------------------------
# Figure search — CLIP embeddings (Phase 5b). SERVER-ONLY. The only feature
# that uses an external runner. Without it, "Index for figure search" and the
# Readroom figure search show a "not set up" notice; everything else works.
# Get a token at https://replicate.com/account/api-tokens
# ----------------------------------------------------------------------------
# REPLICATE_API_TOKEN=
# Optional: override the CLIP model (owner/name, must output 768-d vectors).
# REPLICATE_CLIP_MODEL=krthr/clip-embeddings
