# Copy to .env.local and fill in to enable AI capabilities.
# Get a key at https://openrouter.ai/keys

# Enables all AI features (Explorer, Processor, Writing, Summarize, Ask).
# Without it, AI actions show a "not configured" message.
OPENROUTER_API_KEY=

# Optional: override models. Defaults below.
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_MODEL_FAST=anthropic/claude-haiku-4.5
# OPENROUTER_MODEL_FRONTIER=anthropic/claude-opus-4

# Optional: lifts the aggressive rate limit on the keyless Semantic Scholar endpoint.
# SEMANTIC_SCHOLAR_API_KEY=

# Optional: your app URL (used for OpenRouter rankings/referrer).
# APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Supabase — Phase 1 (Auth + Database + Storage)
# Create a free project at https://supabase.com, then copy these from
# Project Settings → API. When left empty, the app runs in local-only
# (localStorage) mode with no auth and no cloud sync.
# ----------------------------------------------------------------------------

# Required for auth + cloud sync:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# After creating your project, run supabase/schema.sql in the SQL editor.
# Then enable Google OAuth in Auth → Providers → Google.